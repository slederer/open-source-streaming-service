# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Bitmovin
BITMOVIN_API_KEY=your-bitmovin-api-key
BITMOVIN_ORG_ID=your-bitmovin-org-id
BITMOVIN_PLAYER_KEY=your-bitmovin-player-key
BITMOVIN_ANALYTICS_KEY=your-bitmovin-analytics-key

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_INPUT_BUCKET=streaming-input
S3_OUTPUT_BUCKET=streaming-output
S3_THUMBNAIL_BUCKET=streaming-thumbnails
CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# MediaTailor
MEDIATAILOR_VOD_ENDPOINT=https://your-mediatailor-endpoint.mediatailor.us-east-1.amazonaws.com
MEDIATAILOR_LIVE_ENDPOINT=https://your-mediatailor-live-endpoint.mediatailor.us-east-1.amazonaws.com
AD_DECISION_SERVER_URL=https://pubads.g.doubleclick.net/gampad/ads?iu=/21775744923/external/single_ad_samples&sz=640x480&cust_params=sample_ct%3Dlinear&ciu_szs=300x250%2C728x90&gdfp_req=1&output=vast&unviewed_position_start=1&env=vp&impl=s&correlator=

# DoveRunner DRM (formerly PallyCon)
PALLYCON_SITE_ID=your-doverunner-site-id
PALLYCON_SITE_KEY=your-doverunner-site-key
PALLYCON_ACCESS_KEY=your-doverunner-access-key

# Database
DATABASE_URL=postgres://streaming:streaming@localhost:5432/streaming?sslmode=disable

# Server
PORT=8080
API_BASE_URL=http://localhost:8080

# Bitmovin Live
BITMOVIN_LIVE_STREAM_KEY=your-live-stream-key
BITMOVIN_LIVE_ENCODING_ID=
